{
  "name": "ape-relay",
  "version": "0.1.0",
  "description": "Self-hosted message relay: LINE / Discord → Slack",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@line/bot-sdk": "^9.4.0",
    "dotenv": "^16.4.7",
    "discord.js": "^14.16.3",
    "express": "^4.21.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "undici": "^7.3.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
