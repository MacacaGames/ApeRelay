{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug ApeRelay",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/dist/index.js",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "preLaunchTask": "prepare-debug",
      "skipFiles": ["<node_internals>/**"],
      "console": "integratedTerminal",
      "outFiles": ["${workspaceFolder}/dist/**/*.js"]
    },
    {
      "name": "Run test.sh",
      "type": "node-terminal",
      "request": "launch",
      "command": "./test.sh",
      "cwd": "${workspaceFolder}"
    }
  ]
}